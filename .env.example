# Public app URL/domain
APP_DOMAIN=:80
APP_URL=http://localhost

# Postgres is private inside Docker Compose; do not publish its port.
POSTGRES_DB=gomindscout
POSTGRES_USER=gomindscout
POSTGRES_PASSWORD=replace-with-a-long-random-password

# Clerk
VITE_CLERK_PUBLISHABLE_KEY=pk_test_replace_me
VITE_CLERK_PROXY_URL=
CLERK_PUBLISHABLE_KEY=pk_test_replace_me
CLERK_SECRET_KEY=sk_test_replace_me

# Admin login
ADMIN_USERNAME=admin
ADMIN_PASSWORD=replace-with-a-long-random-password
SESSION_SECRET=replace-with-a-long-random-secret

# Stripe. Required for real payments; without STRIPE_SECRET_KEY, bookings use dev auto-confirm behavior.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Hostinger SMTP mailbox
SMTP_HOST=smtp.hostinger.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-mailbox@your-domain.com
SMTP_PASS=replace-with-mailbox-password
FROM_EMAIL="GoMindscout <your-mailbox@your-domain.com>"

# Optional integrations
DAILY_API_KEY=
LOG_LEVEL=info
